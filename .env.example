# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/medical_leave_db
SYNC_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/medical_leave_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-very-long-random-secret-key-here   # openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480   # 8 hours

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=medical-leave-docs
R2_PUBLIC_URL=https://<account-id>.r2.cloudflarestorage.com   # endpoint url

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password   # Use App Password, not account password
EMAIL_FROM_NAME=Medical Leave System

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development   # development | production
APP_BASE_URL=http://localhost:8000
PDF_MAX_SIZE_MB=10
